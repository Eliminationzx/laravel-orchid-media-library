{
  "name": "eliminationzx/laravel-orchid-media-library",
  "description": "Laravel Orchid Media Library Wrapper - Seamless integration of Spatie Media Library with Orchid Platform",
  "type": "package",
  "license": "MIT",
  "keywords": [
    "laravel",
    "orchid",
    "media-library",
    "spatie",
    "admin",
    "cms"
  ],
  "authors": [
    {
      "name": "Eliminationzx",
      "email": "eliminationzx@proton.me",
      "homepage": "https://github.com/Eliminationzx",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "laravel/framework": "^12.0",
    "orchid/platform": "^14.0",
    "eliminationzx/laravel-orchid-helpers": "1.0.4",
    "spatie/laravel-medialibrary": "^11.0"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "orchestra/testbench": "^10.0",
    "phpunit/phpunit": "^12.0",
    "phpstan/phpstan": "^1.10",
    "laravel/pint": "^1.13"
  },
  "autoload": {
    "psr-4": {
      "OrchidMediaLibrary\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\": "stubs/app/",
      "OrchidMediaLibrary\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
    "analyse": "vendor/bin/phpstan analyse",
    "format": "vendor/bin/pint"
  },
  "extra": {
    "laravel": {
      "providers": [
        "OrchidMediaLibrary\\Providers\\FoundationServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
