{
  "name": "eliminationzx/laravel-orchid-media-library",
  "description": "Laravel Orchid Media Library Wrapper",
  "type": "package",
  "license": "MIT",
  "authors": [
    {
      "name": "Andrey Manzadey",
      "email": "andrey.manzadey@gmail.com",
      "homepage": "https://manzaday.ru",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.3",
    "ext-json": "*",
    "eliminationzx/laravel-orchid-helpers": "dev-main",
    "spatie/laravel-medialibrary": "^11.0"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "OrchidMediaLibrary\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\": "stubs/app/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "OrchidMediaLibrary\\Providers\\FoundationServiceProvider"
      ]
    }
  }
}
